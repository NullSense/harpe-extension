{
  "manifest_version": 3,
  "name": "Harpe",
  "version": "1.2.0",
  "description": "Find and download images & videos from any page. Works in-browser; optionally supercharged by the local Harpe engine.",
  "key": "",
  "browser_specific_settings": {
    "gecko": {
      "id": "harpe@nullsense.com"
    }
  },
  "permissions": [
    "scripting",
    "downloads",
    "notifications",
    "storage",
    "sidePanel"
  ],
  "optional_permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Harpe – grab images",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js",
    "scripts": ["js/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
